# Supabase configuration
# Copy this file to .env and fill in your values
# Get these from your Supabase project: https://supabase.com/dashboard

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-public-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Optional: restrict sign-up/login to a specific email domain (e.g. "yourcompany.com")
# Leave unset to allow any email address
# VITE_ALLOWED_EMAIL_DOMAIN="yourcompany.com"

# Edge Function secrets — set with: supabase secrets set KEY=value
#
# GREENHOUSE_API_KEY    — Harvest API key: Greenhouse → Configure → Dev Center → API Credential Management
# LOVABLE_API_KEY       — AI gateway key from Lovable (used for content generation)
#
# Optional: company website URLs for tone/voice analysis (Admin → Sync Knowledge)
# COMPANY_ABOUT_URL     — e.g. "https://yourcompany.com/about"
# COMPANY_CAREERS_URL   — e.g. "https://yourcompany.com/careers"

# GREENHOUSE_API_KEY="your-greenhouse-harvest-api-key"
# LOVABLE_API_KEY="your-lovable-api-key"
# COMPANY_ABOUT_URL="https://yourcompany.com/about"
# COMPANY_CAREERS_URL="https://yourcompany.com/careers"
